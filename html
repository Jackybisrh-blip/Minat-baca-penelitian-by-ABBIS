// ============================================================
// STORAGE HELPERS
// ============================================================
const STORAGE_KEY = "abbis-responses";

async function loadResponses() {
  try {
    const result = await window.storage.get(STORAGE_KEY, true);
    return result ? JSON.parse(result.value) : [];
  } catch { return []; }
}

async function saveResponse(resp) {
  try {
    const existing = await loadResponses();
    existing.push(resp);
    await window.storage.set(STORAGE_KEY, JSON.stringify(existing), true);
    return true;
  } catch { return false; }
}

async function deleteResponse(id) {
  try {
    const existing = await loadResponses();
    const filtered = existing.filter(r => r.id !== id);
    await window.storage.set(STORAGE_KEY, JSON.stringify(filtered), true);
    return true;
  } catch { return false; }
}

// ============================================================
// SCORE CALCULATION
// ============================================================
function calcScore(answers) {
  let c1 = 0, c2 = 0, c3 = 0, d = 0;
  QUESTIONS_C.forEach((q, i) => {
    const key = `C${q.id}`;
    if (answers[key] === q.answer) {
      if (i < 5) c1++;
      else if (i < 10) c2++;
      else c3++;
    }
  });
  QUESTIONS_D.forEach(q => {
    if (answers[`D${q.id}`] === q.answer) d++;
  });
  return { c1, c2, c3, totalC: c1 + c2 + c3, d };
}

