                </div>
                <p style={{ color: "#888", fontSize: "0.8rem" }}>Soal akan otomatis dimulai saat hitungan mundur selesai.</p>
                {printCountdown <= 0 && <button className="btn" onClick={startQuiz}>Mulai Soal Sekarang →</button>}
              </>
            )}
            {printPhase === "done" && (
              <>
                <div className="icon">✅</div>
                <h2>Siap!</h2>
                <p>Waktunya mengerjakan soal. Pastikan teks cetak sudah disingkirkan.</p>
                <button className="btn" onClick={startQuiz}>Mulai Soal →</button>
              </>
            )}
          </div>
        )}

        {/* QUIZ */}
        {page === "quiz" && (
          <div className="quiz-page">
            <div className={`quiz-timer ${quizTimeLeft < 300 ? "timer-urgent" : ""}`}>
              <span>⏱</span>
              <span>Waktu Mengerjakan: <strong>{formatTime(quizTimeLeft)}</strong></span>
              <span style={{ marginLeft: "auto", fontSize: "0.78rem", opacity: 0.75 }}>
                {countAnswered().answered}/{countAnswered().total} dijawab
              </span>
            </div>
            <div className="quiz-progress">
              <div className="quiz-progress-bar" style={{ width: `${(countAnswered().answered / countAnswered().total) * 100}%` }} />
            </div>

            {/* Section C */}
            {quizSection === "C" && (
              <>
                {["C.1", "C.2", "C.3"].map(sec => {
                  const secQ = QUESTIONS_C.filter(q => q.section === sec);
                  return (
                    <div key={sec}>
                      <div className="section-header">{sec} — {secQ[0].label}</div>
                      <div className="section-sub">Jawab tanpa membuka teks.</div>
                      {secQ.map(q => (
                        <div key={q.id} className="question-card">
                          <div className="question-num">Soal {q.id}</div>
                          <div className="question-text">{q.text}</div>
                          <div className="options">
                            {q.options.map((opt, oi) => (
                              <div key={oi} className={`option ${quizAnswers[`C${q.id}`] === oi ? "selected" : ""}`}
                                onClick={() => setQuizAnswers(prev => ({ ...prev, [`C${q.id}`]: oi }))}>
                                <div className="option-letter">{String.fromCharCode(65 + oi)}</div>
                                <span>{opt}</span>
                              </div>
                            ))}
                          </div>
                        </div>
                      ))}
                    </div>
                  );
                })}
                <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 16 }}>
                  <button className="btn" onClick={() => setQuizSection("D")}>Lanjut Bagian D →</button>
                </div>
              </>
            )}

            {/* Section D */}
            {quizSection === "D" && (
              <>
                <div className="section-header">Bagian D — Rekonstruksi Urutan & Memori Lokasi</div>
                <div className="section-sub">Jawab tanpa membuka teks. Teks terdiri dari 9 paragraf bernomor urut.</div>
                {QUESTIONS_D.map(q => (
                  <div key={q.id} className="question-card">
                    <div className="question-num">Soal {q.id}</div>
                    <div className="question-text">{q.text}</div>
                    <div className="options">
                      {q.options.map((opt, oi) => (
                        <div key={oi} className={`option ${quizAnswers[`D${q.id}`] === oi ? "selected" : ""}`}
                          onClick={() => setQuizAnswers(prev => ({ ...prev, [`D${q.id}`]: oi }))}>
                          <div className="option-letter">{String.fromCharCode(65 + oi)}</div>
                          <span>{opt}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
                <div style={{ display: "flex", gap: 12, justifyContent: "flex-end", marginTop: 16 }}>
                  <button className="btn btn-outline" onClick={() => setQuizSection("C")}>← Kembali</button>
                  <button className="btn" onClick={() => { clearInterval(timerRef.current); setPage("scales"); setQuizSection("E"); }}>Lanjut ke Skala →</button>
                </div>
              </>
            )}
          </div>
        )}

        {/* SCALES */}
        {page === "scales" && (
          <div className="quiz-page">
            <div style={{ marginBottom: 24, background: "#f0f7f4", borderRadius: 10, padding: "12px 16px", fontSize: "0.82rem", color: "#1a5235" }}>
              ✅ Soal selesai! Sekarang isi skala pengalaman membacamu. Tidak ada jawaban benar/salah.
            </div>

            {quizSection === "E" && (
              <>
                <div className="section-header">Bagian E — Skala Beban Kognitif</div>
                <div className="section-sub">Berikan tanda pada kolom yang paling menggambarkan pengalamanmu selama membaca teks tadi. (1=Sangat Tidak Setuju, 5=Sangat Setuju)</div>
                {SCALE_E.map(item => (
                  <div key={item.id} className="likert-card">
                    <div className="likert-text">{item.text} {item.reversed && <span style={{ color: "#888", fontSize: "0.75rem" }}>(R)</span>}</div>
                    <div className="likert-scale">
                      <div className="likert-label">STS</div>
                      <div className="likert-options">
                        {[1, 2, 3, 4, 5].map(v => (
                          <button key={v} className={`likert-btn ${scaleAnswers[item.id] === v ? "selected" : ""}`}
                            onClick={() => setScaleAnswers(prev => ({ ...prev, [item.id]: v }))}>{v}</button>
                        ))}
                      </div>
                      <div className="likert-label">SS</div>
                    </div>
                  </div>
                ))}
                <div style={{ display: "flex", justifyContent: "flex-end", marginTop: 16 }}>
                  <button className="btn" onClick={() => setQuizSection("F")}>Lanjut →</button>
                </div>
              </>
            )}

            {quizSection === "F" && (
              <>
                <div className="section-header">Bagian F — Skala Memori Spasial & Stabilitas Teks</div>
                <div className="section-sub">Berikan tanda setelah selesai membaca. (1=Sangat Tidak Setuju, 5=Sangat Setuju)</div>
                {SCALE_F.map(item => (
                  <div key={item.id} className="likert-card">
                    <div className="likert-text">{item.text} {item.reversed && <span style={{ color: "#888", fontSize: "0.75rem" }}>(R)</span>}</div>
                    <div className="likert-scale">
                      <div className="likert-label">STS</div>
                      <div className="likert-options">
                        {[1, 2, 3, 4, 5].map(v => (
                          <button key={v} className={`likert-btn ${scaleAnswers[item.id] === v ? "selected" : ""}`}
                            onClick={() => setScaleAnswers(prev => ({ ...prev, [item.id]: v }))}>{v}</button>
                        ))}
                      </div>
                      <div className="likert-label">SS</div>
                    </div>
                  </div>
                ))}
                <div style={{ display: "flex", gap: 12, justifyContent: "flex-end", marginTop: 16 }}>
                  <button className="btn btn-outline" onClick={() => setQuizSection("E")}>← Kembali</button>
                  <button className="btn" onClick={() => setQuizSection("G")}>Lanjut →</button>
                </div>
              </>
            )}

            {quizSection === "G" && (
              <>
                <div className="section-header">Bagian G — Skala Pengalaman Membaca Umum</div>
                <div className="section-sub">Berikan tanda berdasarkan pengalaman keseluruhanmu. (1=Sangat Tidak Setuju, 5=Sangat Setuju)</div>
                {SCALE_G.map(item => (
                  <div key={item.id} className="likert-card">
                    <div className="likert-text">{item.text}</div>
                    <div className="likert-scale">
                      <div className="likert-label">STS</div>
                      <div className="likert-options">
                        {[1, 2, 3, 4, 5].map(v => (
                          <button key={v} className={`likert-btn ${scaleAnswers[item.id] === v ? "selected" : ""}`}
                            onClick={() => setScaleAnswers(prev => ({ ...prev, [item.id]: v }))}>{v}</button>
                        ))}
                      </div>
                      <div className="likert-label">SS</div>
                    </div>
                  </div>
                ))}
                <div style={{ display: "flex", gap: 12, justifyContent: "flex-end", marginTop: 16 }}>
                  <button className="btn btn-outline" onClick={() => setQuizSection("F")}>← Kembali</button>
                  <button className="btn" disabled={saving} onClick={handleSubmit}>
                    {saving ? "Mengirim..." : "✓ Kirim Jawaban"}
                  </button>
                </div>
              </>
            )}
          </div>
        )}

        {/* RESULT */}
        {page === "result" && result && (
          <div className="result-page">
            <h2>🎉 Terima Kasih!</h2>
            <p className="sub">Jawabanmu telah berhasil dikirim ke server penelitian.</p>
            <div className="result-msg">{saveMsg}</div>
            <div className="total-score">
              <div className="val">{result.score.totalC + result.score.d}</div>
              <div className="lbl">Total Skor (C + D) dari 23</div>
            </div>
            <div className="score-grid">
              <div className="score-card">
                <div className="val">{result.score.c1}</div>
                <div className="max">/ 5</div>
                <div className="lbl">C.1 Surface Code</div>
              </div>
              <div className="score-card">
                <div className="val">{result.score.c2}</div>
                <div className="max">/ 5</div>
                <div className="lbl">C.2 Textbase</div>
              </div>
              <div className="score-card">
                <div className="val">{result.score.c3}</div>
                <div className="max">/ 5</div>
                <div className="lbl">C.3 Situation Model</div>
              </div>
              <div className="score-card">
                <div className="val">{result.score.d}</div>
                <div className="max">/ 8</div>
                <div className="lbl">D — Memori Lokasi</div>
              </div>
            </div>
            <p style={{ color: "#888", fontSize: "0.8rem", textAlign: "center", marginTop: 8 }}>
              Data lengkap termasuk skala E, F, G telah tersimpan dan hanya dapat diakses oleh peneliti.
            </p>
          </div>
        )}

        {/* ADMIN PAGE */}
        {page === "admin" && adminAuth && (
          <div className="admin-page">
            <h2>Panel Admin — Peneliti</h2>
            <p style={{ color: "#888", fontSize: "0.82rem", marginBottom: 8 }}>Data responden tersimpan di server bersama. Hanya dapat diakses dengan kata sandi.</p>
            <div className="admin-tabs">
              <div className={`admin-tab ${adminTab === "data" ? "active" : ""}`} onClick={() => { setAdminTab("data"); loadAdminData(); }}>📊 Data Responden</div>
              <div className={`admin-tab ${adminTab === "stats" ? "active" : ""}`} onClick={() => { setAdminTab("stats"); loadAdminData(); }}>📈 Statistik</div>
              <div className={`admin-tab ${adminTab === "editor" ? "active" : ""}`} onClick={() => setAdminTab("editor")}>✏️ Info Instrumen</div>
            </div>

            {adminTab === "data" && (
              <>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 12 }}>
                  <span style={{ fontSize: "0.85rem", color: "#666" }}>{responses.length} responden terdaftar</span>
                  <button className="btn btn-sm btn-outline" onClick={loadAdminData}>↻ Refresh</button>
                </div>
                {responses.length === 0 ? (
                  <div style={{ textAlign: "center", padding: 40, color: "#888" }}>Belum ada data responden.</div>
                ) : (
                  <table className="resp-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Nama</th>
                        <th>Kelas/Absen</th>
                        <th>Media</th>
                        <th>Skor C</th>
                        <th>Skor D</th>
                        <th>Total</th>
                        <th>Waktu</th>
                        <th>Aksi</th>
                      </tr>
                    </thead>
                    <tbody>
                      {responses.map((r, i) => (
                        <tr key={r.id}>
                          <td style={{ color: "#999" }}>{i + 1}</td>
                          <td style={{ fontWeight: 600 }}>{r.nama}</td>
                          <td>{r.kelas} / {r.absen}</td>
                          <td><span className={`badge-media ${r.media === "digital" ? "badge-digital" : "badge-cetak"}`}>{r.media === "digital" ? "Digital" : "Cetak"}</span></td>
                          <td>{r.score?.totalC ?? "-"}/15</td>
                          <td>{r.score?.d ?? "-"}/8</td>
                          <td style={{ fontWeight: 700 }}>{(r.score?.totalC ?? 0) + (r.score?.d ?? 0)}/23</td>
                          <td>{r.timeSpent ? Math.floor(r.timeSpent / 60) + "m" : "-"}</td>
                          <td>
                            <div style={{ display: "flex", gap: 4 }}>
                              <button className="btn btn-sm btn-outline" onClick={() => setSelectedResp(selectedResp?.id === r.id ? null : r)}>Detail</button>
                              <button className="btn btn-sm btn-danger" onClick={() => { setDeleteTarget(r); setDeletePass(""); setDeleteError(""); }}>Hapus</button>
                            </div>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                )}

                {selectedResp && (
                  <div className="detail-view">
                    <h3 style={{ fontFamily: "Lora, serif", marginBottom: 16 }}>Detail: {selectedResp.nama}</h3>
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16 }}>
                      <div className="detail-section">
                        <h4>Data Diri</h4>
                        <div className="detail-row"><span>Nama</span><span>{selectedResp.nama}</span></div>
                        <div className="detail-row"><span>Kelas</span><span>{selectedResp.kelas}</span></div>
                        <div className="detail-row"><span>No. Absen</span><span>{selectedResp.absen}</span></div>
                        <div className="detail-row"><span>Gender</span><span>{selectedResp.gender === "L" ? "Laki-laki" : "Perempuan"}</span></div>
                        <div className="detail-row"><span>Media</span><span>{selectedResp.media}</span></div>
                        <div className="detail-row"><span>Waktu Kerja</span><span>{selectedResp.timeSpent ? Math.floor(selectedResp.timeSpent / 60) + " menit " + (selectedResp.timeSpent % 60) + " detik" : "-"}</span></div>
                        <div className="detail-row"><span>Timestamp</span><span style={{ fontSize: "0.75rem" }}>{new Date(selectedResp.timestamp).toLocaleString("id-ID")}</span></div>
                      </div>
                      <div className="detail-section">
                        <h4>Skor Objektif</h4>
                        <div className="detail-row"><span>C.1 Surface Code</span><span>{selectedResp.score?.c1}/5</span></div>
                        <div className="detail-row"><span>C.2 Textbase</span><span>{selectedResp.score?.c2}/5</span></div>
                        <div className="detail-row"><span>C.3 Situation Model</span><span>{selectedResp.score?.c3}/5</span></div>
                        <div className="detail-row"><span>Total C</span><span style={{ fontWeight: 700 }}>{selectedResp.score?.totalC}/15</span></div>
                        <div className="detail-row"><span>D — Memori Lokasi</span><span style={{ fontWeight: 700 }}>{selectedResp.score?.d}/8</span></div>
                        <div className="detail-row"><span><strong>Total C+D</strong></span><span style={{ fontWeight: 700, color: "#1a3a2a" }}>{(selectedResp.score?.totalC ?? 0) + (selectedResp.score?.d ?? 0)}/23</span></div>
                      </div>
                    </div>
                    <div className="detail-section" style={{ marginTop: 16 }}>
                      <h4>Skala Likert (E — Beban Kognitif)</h4>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 8 }}>
                        {SCALE_E.map(item => (
                          <div key={item.id} style={{ background: "#f0f7f4", borderRadius: 6, padding: "4px 10px", fontSize: "0.75rem" }}>
                            <strong>{item.id}:</strong> {selectedResp.scales?.[item.id] ?? "-"}
                          </div>
                        ))}
                      </div>
                    </div>
                    <div className="detail-section">
                      <h4>Skala Likert (F — Memori Spasial)</h4>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 8 }}>
                        {SCALE_F.map(item => (
                          <div key={item.id} style={{ background: "#f0f7f4", borderRadius: 6, padding: "4px 10px", fontSize: "0.75rem" }}>
                            <strong>{item.id}:</strong> {selectedResp.scales?.[item.id] ?? "-"}
                          </div>
                        ))}
                      </div>
                    </div>
                    <div className="detail-section">
                      <h4>Skala Likert (G — Pengalaman Umum)</h4>
                      <div style={{ display: "flex", flexWrap: "wrap", gap: 8 }}>
                        {SCALE_G.map(item => (
                          <div key={item.id} style={{ background: "#f0f7f4", borderRadius: 6, padding: "4px 10px", fontSize: "0.75rem" }}>
                            <strong>{item.id}:</strong> {selectedResp.scales?.[item.id] ?? "-"}
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                )}
              </>
            )}

            {adminTab === "stats" && (
              <div>
                {responses.length === 0 ? (
                  <div style={{ textAlign: "center", padding: 40, color: "#888" }}>Belum ada data untuk ditampilkan.</div>
                ) : (
                  <>
                    {["digital", "cetak"].map(media => {
                      const group = responses.filter(r => r.media === media);
                      if (!group.length) return null;
                      const avgC = (group.reduce((s, r) => s + (r.score?.totalC ?? 0), 0) / group.length).toFixed(2);
                      const avgD = (group.reduce((s, r) => s + (r.score?.d ?? 0), 0) / group.length).toFixed(2);
                      const avgTotal = (group.reduce((s, r) => s + ((r.score?.totalC ?? 0) + (r.score?.d ?? 0)), 0) / group.length).toFixed(2);
                      return (
                        <div key={media} style={{ background: "white", borderRadius: 14, padding: 24, marginBottom: 16, boxShadow: "0 2px 10px rgba(0,0,0,0.06)" }}>
                          <h3 style={{ fontFamily: "Lora, serif", marginBottom: 16, color: "#1a3a2a" }}>
                            {media === "digital" ? "💻 Kelompok Digital" : "📄 Kelompok Cetak"} — {group.length} responden
                          </h3>
                          <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 12 }}>
                            <div className="score-card"><div className="val">{avgC}</div><div className="lbl">Rata-rata C (max 15)</div></div>
                            <div className="score-card"><div className="val">{avgD}</div><div className="lbl">Rata-rata D (max 8)</div></div>
                            <div className="score-card"><div className="val">{avgTotal}</div><div className="lbl">Rata-rata Total (max 23)</div></div>
                          </div>
                        </div>
                      );
                    })}
                    <div style={{ background: "#1a3a2a", color: "#e8dfc8", borderRadius: 14, padding: 20, marginTop: 16 }}>
                      <div style={{ fontFamily: "Lora, serif", marginBottom: 12, fontSize: "1.05rem" }}>Ringkasan Keseluruhan</div>
                      <div className="detail-row" style={{ color: "#e8dfc8", borderColor: "#2d6a4f" }}>
                        <span>Total Responden</span><span>{responses.length}</span>
                      </div>
                      <div className="detail-row" style={{ color: "#e8dfc8", borderColor: "#2d6a4f" }}>
                        <span>Kelompok Digital</span><span>{responses.filter(r => r.media === "digital").length}</span>
                      </div>
                      <div className="detail-row" style={{ color: "#e8dfc8", borderColor: "#2d6a4f" }}>
                        <span>Kelompok Cetak</span><span>{responses.filter(r => r.media === "cetak").length}</span>
                      </div>
                    </div>
                  </>
                )}
              </div>
            )}

            {adminTab === "editor" && (
              <div className="editor-section">
                <div className="editor-note">
                  ℹ️ Halaman ini menampilkan informasi instrumen. Untuk memodifikasi teks atau soal, diperlukan akses ke kode sumber aplikasi. Hubungi pengembang untuk perubahan mendalam.
                </div>
                <h4 style={{ fontFamily: "Lora, serif", marginBottom: 12 }}>Struktur Instrumen</h4>
                <div className="detail-row"><span>Bagian A</span><span>Data Diri Responden</span></div>
                <div className="detail-row"><span>Bagian B</span><span>Teks Bacaan (~900 kata, 9 paragraf)</span></div>
                <div className="detail-row"><span>Bagian C.1</span><span>5 Soal — Surface Code (Pemahaman Harfiah)</span></div>
                <div className="detail-row"><span>Bagian C.2</span><span>5 Soal — Textbase (Ide Pokok)</span></div>
                <div className="detail-row"><span>Bagian C.3</span><span>5 Soal — Situation Model (Inferensial)</span></div>
                <div className="detail-row"><span>Bagian D</span><span>8 Soal — Rekonstruksi Urutan & Memori Lokasi</span></div>
                <div className="detail-row"><span>Bagian E</span><span>10 Item Likert — Skala Beban Kognitif</span></div>
                <div className="detail-row"><span>Bagian F</span><span>8 Item Likert — Memori Spasial & Stabilitas</span></div>
                <div className="detail-row"><span>Bagian G</span><span>6 Item Likert — Pengalaman Membaca Umum</span></div>
                <div className="detail-row"><span>Waktu Pengerjaan Soal</span><span>30 menit</span></div>
                <div className="detail-row"><span>Waktu Singkirkan Teks (Cetak)</span><span>3 menit</span></div>
                <div style={{ marginTop: 24 }}>
                  <h4 style={{ fontFamily: "Lora, serif", marginBottom: 12 }}>Link untuk Dibagikan</h4>
                  <div style={{ background: "#f0ebe3", borderRadius: 8, padding: 12, fontFamily: "monospace", fontSize: "0.82rem", wordBreak: "break-all" }}>
                    {window.location.href.split("#")[0]}
                  </div>
                  <p style={{ fontSize: "0.78rem", color: "#888", marginTop: 8 }}>Bagikan link di atas kepada responden. Untuk akses admin, tambahkan <code>#admin</code> di akhir URL.</p>
                </div>
              </div>
            )}
          </div>
        )}

        {/* ADMIN LOGIN MODAL */}
        {showAdminModal && (
          <div className="modal-overlay" onClick={() => setShowAdminModal(false)}>
            <div className="modal" onClick={e => e.stopPropagation()}>
              <h3>🔐 Akses Admin</h3>
              <p>Masukkan kata sandi untuk mengakses panel peneliti.</p>
              <input
                type="password"
                placeholder="Kata sandi admin..."
                value={adminPassword}
                onChange={e => setAdminPassword(e.target.value)}
                onKeyDown={e => e.key === "Enter" && handleAdminLogin()}
              />
              {adminError && <div className="error-msg">⚠️ {adminError}</div>}
              <div style={{ display: "flex", gap: 10 }}>
                <button className="btn btn-outline" style={{ flex: 1 }} onClick={() => { setShowAdminModal(false); setAdminError(""); }}>Batal</button>
                <button className="btn" style={{ flex: 1 }} onClick={handleAdminLogin}>Masuk</button>
              </div>
            </div>
          </div>
        )}

        {/* DELETE MODAL */}
        {deleteTarget && (
          <div className="modal-overlay">
            <div className="modal">
              <h3>🗑️ Hapus Responden</h3>
              <p>Kamu akan menghapus data <strong>{deleteTarget.nama}</strong>. Tindakan ini tidak dapat dibatalkan. Masukkan kata sandi admin untuk konfirmasi.</p>
              <input
                type="password"
                placeholder="Kata sandi admin..."
                value={deletePass}
                onChange={e => setDeletePass(e.target.value)}
                onKeyDown={e => e.key === "Enter" && handleDelete()}
              />
              {deleteError && <div className="error-msg">⚠️ {deleteError}</div>}
              <div style={{ display: "flex", gap: 10 }}>
                <button className="btn btn-outline" style={{ flex: 1 }} onClick={() => { setDeleteTarget(null); setDeleteError(""); }}>Batal</button>
                <button className="btn btn-danger" style={{ flex: 1 }} onClick={handleDelete}>Hapus</button>
              </div>
            </div>
          </div>
        )}
      </div>
    </>
  );
}
