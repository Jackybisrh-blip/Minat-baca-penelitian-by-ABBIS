// MAIN APP
// ============================================================
export default function App() {
  const [page, setPage] = useState("landing"); // landing | form | reading | print-info | quiz | scales | result | admin
  const [mediaType, setMediaType] = useState(null); // digital | cetak
  const [userData, setUserData] = useState({ nama: "", kelas: "", absen: "", gender: "" });
  const [hasRead, setHasRead] = useState(false);
  const [quizAnswers, setQuizAnswers] = useState({});
  const [scaleAnswers, setScaleAnswers] = useState({});
  const [quizTimeLeft, setQuizTimeLeft] = useState(QUIZ_TIME_SECONDS);
  const [quizStartTime, setQuizStartTime] = useState(null);
  const [printCountdown, setPrintCountdown] = useState(null); // null = not started
  const [printPhase, setPrintPhase] = useState("instruksi"); // instruksi | countdown | done
  const [result, setResult] = useState(null);
  const [adminAuth, setAdminAuth] = useState(false);
  const [adminPassword, setAdminPassword] = useState("");
  const [adminError, setAdminError] = useState("");
  const [showAdminModal, setShowAdminModal] = useState(false);
  const [adminTab, setAdminTab] = useState("data");
  const [responses, setResponses] = useState([]);
  const [selectedResp, setSelectedResp] = useState(null);
  const [deleteTarget, setDeleteTarget] = useState(null);
  const [deletePass, setDeletePass] = useState("");
  const [deleteError, setDeleteError] = useState("");
  const [quizSection, setQuizSection] = useState("C"); // C | D | E | F | G
  const [saving, setSaving] = useState(false);
  const [saveMsg, setSaveMsg] = useState("");
  const timerRef = useRef(null);
  const printTimerRef = useRef(null);

  // URL-based routing for sharing
  useEffect(() => {
    const hash = window.location.hash;
    if (hash === "#admin") { setShowAdminModal(true); }
  }, []);

  // Quiz timer
  useEffect(() => {
    if (page === "quiz" && quizStartTime) {
      timerRef.current = setInterval(() => {
        const elapsed = Math.floor((Date.now() - quizStartTime) / 1000);
        const left = QUIZ_TIME_SECONDS - elapsed;
        if (left <= 0) {
          clearInterval(timerRef.current);
          setQuizTimeLeft(0);
          handleQuizDone();
        } else {
          setQuizTimeLeft(left);
        }
      }, 1000);
      return () => clearInterval(timerRef.current);
    }
  }, [page, quizStartTime]);

  function startQuiz() {
    setQuizStartTime(Date.now());
    setPage("quiz");
    setQuizSection("C");
  }

  function handleReadingDone() {
    clearInterval(timerRef.current);
    startQuiz();
  }

  // Print countdown (3 minutes to put away the paper)
  function startPrintCountdown() {
    setPrintPhase("countdown");
    let secs = 3 * 60;
    setPrintCountdown(secs);
    printTimerRef.current = setInterval(() => {
      secs--;
      setPrintCountdown(secs);
      if (secs <= 0) {
        clearInterval(printTimerRef.current);
        setPrintPhase("done");
      }
    }, 1000);
  }

  function formatTime(s) {
    const m = Math.floor(s / 60).toString().padStart(2, "0");
    const sec = (s % 60).toString().padStart(2, "0");
    return `${m}:${sec}`;
  }

  function handleQuizDone() {
    clearInterval(timerRef.current);
    if (quizSection !== "G") {
      // move to scales
      setPage("scales");
      setQuizSection("E");
    }
  }

  async function handleSubmit() {
    if (saving) return;
    setSaving(true);
    const score = calcScore(quizAnswers);
    const resp = {
      id: Date.now().toString(),
      timestamp: new Date().toISOString(),
      nama: userData.nama,
      kelas: userData.kelas,
      absen: userData.absen,
      gender: userData.gender,
      media: mediaType,
      answers: { ...quizAnswers },
      scales: { ...scaleAnswers },
      score,
      timeSpent: QUIZ_TIME_SECONDS - quizTimeLeft,
    };
    setResult(resp);
    const ok = await saveResponse(resp);
    setSaveMsg(ok ? "Data berhasil dikirim ke server penelitian." : "Gagal mengirim data. Coba lagi.");
    setSaving(false);
    setPage("result");
  }

  // Admin
  async function loadAdminData() {
    const data = await loadResponses();
    setResponses(data);
  }

  function handleAdminLogin() {
    if (adminPassword === ADMIN_PASSWORD) {
      setAdminAuth(true);
      setShowAdminModal(false);
      setAdminError("");
      setPage("admin");
      loadAdminData();
    } else {
      setAdminError("Kata sandi salah.");
    }
  }

  async function handleDelete() {
    if (deletePass !== ADMIN_PASSWORD) { setDeleteError("Kata sandi salah."); return; }
    await deleteResponse(deleteTarget.id);
    setDeleteTarget(null);
    setDeletePass("");
    setDeleteError("");
    if (selectedResp?.id === deleteTarget.id) setSelectedResp(null);
    loadAdminData();
  }

  const allQuestionsSections = ["C", "D"];
  const allScaleSections = ["E", "F", "G"];

  function countAnswered() {
    let total = 0;
    if (page === "quiz") {
      const allQ = [...QUESTIONS_C, ...QUESTIONS_D];
      total = allQ.filter(q => {
        const key = q.id <= 15 ? `C${q.id}` : `D${q.id}`;
        return quizAnswers[key] !== undefined;
      }).length;
      return { answered: total, total: allQ.length };
    }
    return { answered: 0, total: 0 };
  }

  // ---- RENDER ----
  return (
    <>
      <style>{css}</style>
      <div className="app">
        <div className="header">
          <div>
            <div className="header-title">Instrumen Penelitian ABBIS</div>
            <div className="header-sub">Perbandingan Pemahaman Membaca — SMAN 5 Yogyakarta 2025/2026</div>
          </div>
          {mediaType && <div className="header-badge">{mediaType === "digital" ? "📱 DIGITAL" : "📄 CETAK"}</div>}
        </div>

        {/* LANDING */}
        {page === "landing" && (
          <div className="landing">
            <div className="landing-icon">📖</div>
            <h1>Penelitian Pemahaman Membaca</h1>
            <p>Selamat datang! Kamu akan mengikuti penelitian tentang perbandingan pemahaman membaca antara media cetak dan digital. Pilih kelompokmu di bawah ini.</p>
            <div className="media-cards">
              <div className={`media-card ${mediaType === "digital" ? "selected" : ""}`} onClick={() => setMediaType("digital")}>
                <div className="media-card-icon">💻</div>
                <h3>Kelompok Digital</h3>
                <p>Membaca teks langsung di layar, kemudian mengerjakan soal tanpa bisa kembali ke teks.</p>
              </div>
              <div className={`media-card ${mediaType === "cetak" ? "selected" : ""}`} onClick={() => setMediaType("cetak")}>
                <div className="media-card-icon">📄</div>
                <h3>Kelompok Cetak</h3>
                <p>Membaca teks dari kertas yang sudah dicetak, kemudian ada waktu untuk menyingkirkan kertas sebelum mengerjakan soal.</p>
              </div>
            </div>
            <button className="btn" disabled={!mediaType} onClick={() => setPage("form")}>Mulai →</button>
            <span className="admin-link" onClick={() => setShowAdminModal(true)}>Panel Admin / Peneliti</span>
          </div>
        )}

        {/* DATA DIRI */}
        {page === "form" && (
          <div className="form-page">
            <h2>Bagian A — Data Diri</h2>
            <p className="subtitle">Isi data diri dengan lengkap sebelum memulai.</p>
            <div className="form-group">
              <label>Nama Lengkap</label>
              <input value={userData.nama} onChange={e => setUserData({ ...userData, nama: e.target.value })} placeholder="Nama lengkap..." />
            </div>
            <div className="form-group">
              <label>Kelas</label>
              <input value={userData.kelas} onChange={e => setUserData({ ...userData, kelas: e.target.value })} placeholder="Contoh: XII IPA 1" />
            </div>
            <div className="form-group">
              <label>No. Absen</label>
              <input value={userData.absen} onChange={e => setUserData({ ...userData, absen: e.target.value })} placeholder="Nomor absen" />
            </div>
            <div className="form-group">
              <label>Jenis Kelamin</label>
              <div className="radio-group">
                <div className={`radio-btn ${userData.gender === "L" ? "active" : ""}`} onClick={() => setUserData({ ...userData, gender: "L" })}>
                  <span>♂</span> Laki-laki
                </div>
                <div className={`radio-btn ${userData.gender === "P" ? "active" : ""}`} onClick={() => setUserData({ ...userData, gender: "P" })}>
                  <span>♀</span> Perempuan
                </div>
              </div>
            </div>
            <div style={{ display: "flex", gap: 12, marginTop: 28 }}>
              <button className="btn btn-outline" onClick={() => setPage("landing")}>← Kembali</button>
              <button className="btn" disabled={!userData.nama || !userData.kelas || !userData.absen || !userData.gender}
                onClick={() => mediaType === "digital" ? setPage("reading") : setPage("print-info")}>
                Lanjut →
              </button>
            </div>
          </div>
        )}

        {/* READING (DIGITAL) */}
        {page === "reading" && (
          <div className="reading-page">
            <div className="reading-header">
              <span className="reading-badge">📖 Bagian B — Teks Bacaan Digital</span>
              <span style={{ fontSize: "0.8rem", color: "#888" }}>Baca sekali dengan saksama</span>
            </div>
            <div className="reading-note">
              ⚠️ <strong>Perhatian:</strong> Baca teks ini satu kali dengan seksama. Setelah menekan "Selesai Membaca", kamu <strong>tidak dapat kembali</strong> ke teks ini dan langsung mengerjakan soal.
            </div>
